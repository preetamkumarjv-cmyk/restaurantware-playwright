{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "lib":              ["ES2020"],
    "strict":           false,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "skipLibCheck":     true,
    "types":            ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "components/**/*.ts",
    "fixtures/**/*.ts",
    "utils/**/*.ts",
    "constants/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
